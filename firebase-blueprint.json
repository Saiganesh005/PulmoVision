{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "medId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Doctor", "Radiologist", "Admin", "Researcher"] }
      },
      "required": ["uid", "medId", "name", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
